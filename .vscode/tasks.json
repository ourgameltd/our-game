{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Infra: Start Local Stack",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-p",
        "infrastructure",
        "-f",
        "docker-compose.local.yml",
        "up",
        "-d"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "infra"
      },
      "problemMatcher": []
    },
    {
      "label": "Infra: Stop Local Stack",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-p",
        "infrastructure",
        "-f",
        "docker-compose.local.yml",
        "down"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "infra"
      },
      "problemMatcher": []
    },
    {
      "label": "API: Start Functions",
      "type": "shell",
      "command": "func",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/api/OurGame.Api",
        "env": {
          "DOTNET_ROOT": "/opt/homebrew/opt/dotnet@8/libexec",
          "PATH": "/opt/homebrew/opt/dotnet@8/bin:${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Azure Functions Core Tools.*$",
            "endsPattern": "^.*Worker process started and initialized.*$"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "api"
      }
    },
    {
      "label": "Web: SWA CLI",
      "type": "shell",
      "command": "npx",
      "args": [
        "swa",
        "start",
        "--config",
        "swa-cli.config.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "web"
      }
    },
    {
      "label": "DB: Seed",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-p",
        "infrastructure",
        "-f",
        "docker-compose.local.yml",
        "--profile",
        "seed",
        "run",
        "--no-deps",
        "--rm",
        "seeder"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "infra"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev: Start (func + SWA)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "API: Start Functions",
        "Web: SWA CLI"
      ],
      "problemMatcher": []
    },
    {
      "label": "Dev: Start Backend Containers + SWA",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Infra: Start Local Stack",
        "DB: Seed",
        "API: Start Functions",
        "Web: SWA CLI"
      ],
      "problemMatcher": []
    }
  ]
}
