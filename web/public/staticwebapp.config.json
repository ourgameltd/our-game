{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/images/*.{png,jpg,gif}",
      "/css/*"
    ]
  },
  "mimeTypes": {
    ".json": "text/json"
  },
  "routes": [

    {
      "route": "/.auth/login/twitter",
      "statusCode": 401
    },
    {
      "route": "/.auth/login/facebook",
      "statusCode": 401
    },
    {
      "route": "/.auth/login/google",
      "statusCode": 401
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 401
    },
    {
      "route": "/.auth/login/apple",
      "statusCode": 401
    },
    {
      "route": "/.auth/login/aad",
      "statusCode": 401
    },
    {
      "route": "/api/GetRoles",
      "methods": [
        "POST"
      ],
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    },
    {
      "route": "/api/claim*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/lookup*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/404",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/error/acces",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/redirect",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/terms",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/privacy",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/play*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/css*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/js*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/images*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/fonts*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/scss*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/ajax*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.png",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.xml",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.ico",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.svg",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.webmanifest",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/assets/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.js",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.css",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/_next*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*.txt",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://dc.services.visualstudio.com; frame-ancestors 'none'"
  },
  "auth": {
    "rolesSource": "/api/GetRoles",
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "b2c": {
          "registration": {
            "clientIdSettingName": "B2C_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "B2C_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://ourgameauth.b2clogin.com/ourgameauth.onmicrosoft.com/B2C_1_SUSI/v2.0/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name",
            "scopes": [
              "offline_access",
              "openid",
              "https://ourgameauth.onmicrosoft.com/app-api/app.read",
              "https://ourgameauth.onmicrosoft.com/app-api/app.write"
            ]
          }
        }
      }
    }
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/b2c"
    }
  }
}
