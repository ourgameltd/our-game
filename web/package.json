{
  "name": "football-club-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "screenshots": "node scripts/capture-screenshots.js",
    "screenshots:clean": "node -e \"require('fs').rmSync('screenshots', {recursive: true, force: true})\"",
    "generate:api": "echo 'NSwag client generation - requires openapi.json from running API. Start API with func start, then run: npx @hey-api/openapi-ts -i http://localhost:7071/api/openapi/v3.json -o src/api/generated -c axios'"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@material-tailwind/react": "2.1.10",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@tailwindcss/typography": "0.5.19",
    "axios": "1.14.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.3",
    "recharts": "3.5.1",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.5",
    "@storybook/addon-links": "10.3.3",
    "@storybook/react": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@types/node": "25.5.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "gh-pages": "6.3.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "puppeteer": "24.40.0",
    "storybook": "10.3.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "8.0.3"
  }
}
